# ─── Lumicore — Production Environment Template ───────────────────────────────
# Copy to /opt/lumicore/.env on VPS and fill in real values.
# Never commit this file with real secrets.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=lumicore
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=lumicore

# ─── API — JWT ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME
REFRESH_TOKEN_SECRET=CHANGE_ME
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── API — AWS S3 (file uploads) ──────────────────────────────────────────────
AWS_S3_BUCKET=lumicore-files
AWS_S3_REGION=eu-north-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ─── API — SMTP (email invitations) ──────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME

# ─── API — SMS (OTP / invitations) ───────────────────────────────────────────
SMS_PROVIDER_API_KEY=CHANGE_ME

# ─── API — CORS ───────────────────────────────────────────────────────────────
# Must match your domain exactly (no trailing slash)
CORS_ORIGIN=https://YOUR_DOMAIN
SOCKET_CORS_ORIGIN=https://YOUR_DOMAIN

# ─── Docker image tags (set by CI, override for manual deploy) ────────────────
# IMAGE_API=ghcr.io/YOUR_ORG/lumicore-api:latest
# IMAGE_WEB=ghcr.io/YOUR_ORG/lumicore-web:latest
