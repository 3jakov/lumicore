{
  "expo": {
    "name": "Lumicore",
    "slug": "lumicore",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ee.lumico.lumicore"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "ee.lumico.lumicore"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Lumicore needs camera access to capture job-site photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Lumicore uses your location to tag job-site photos with GPS coordinates."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F59E0B",
          "sounds": [],
          "mode": "production"
        }
      ]
    ],
    "scheme": "lumicore",
    "extra": {
      "apiUrl": "http://localhost:3001/api/v1",
      "wsUrl": "ws://localhost:3001",
      "eas": {}
    }
  }
}
