{
  "name": "lumicore",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @lumicore/api start:dev",
    "dev:web": "pnpm --filter @lumicore/web dev",
    "build:api": "pnpm --filter @lumicore/api build",
    "build:web": "pnpm --filter @lumicore/web build",
    "typecheck": "pnpm --filter @lumicore/shared-types build && pnpm --filter @lumicore/api typecheck && pnpm --filter @lumicore/web typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,json,yaml,yml,md}\" --ignore-path .gitignore",
    "test": "pnpm --filter @lumicore/api test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0"
    }
  },
  "dependencies": {
    "socket.io": "^4.8.3"
  }
}
